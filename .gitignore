# WordPress Standard Gitignore
# ----------------------------

# Core
# Comment out the next line if you want to track WordPress core
# wp-admin/
# wp-includes/
# *.php
# !wp-content/

# Configuration
Agrovial-ant/
wp-config.php
.htaccess
sitemap.xml
sitemap.xml.gz

# Content
ai1wm-backups/
wp-content/uploads/
wp-content/blogs.dir/
wp-content/upgrade/
wp-content/backup-db/
wp-content/cache/
wp-content/advanced-cache.php
wp-content/wp-cache-config.php
wp-content/plugins/hello.php

# Languages
wp-content/languages/

# Plugins and Themes (Uncomment if you only want to track your custom ones)
# wp-content/plugins/*
# wp-content/themes/*
# !wp-content/themes/agrovial-theme/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Docker
docker-compose.override.yml
